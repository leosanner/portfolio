  },
  "homepage": "https://github.com/leosanner/portfolio#readme",
  "dependencies": {
    "@hono/vite-dev-server": "^0.25.1",
    "better-auth": "^1.5.6",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.9",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
