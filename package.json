{
  "name": "portfolio",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && wrangler deploy --dry-run --outdir dist",
    "preview": "wrangler dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply portfolio-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply portfolio-db --remote",
    "deploy": "wrangler deploy"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leosanner/portfolio.git"
  },
  "keywords": [],
